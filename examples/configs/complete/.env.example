# Example environment variables for the complete config.
# Real values depend on your API providers and deployment.

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  WARNING: DO NOT USE THIS PRIVATE KEY IN PRODUCTION                          ║
# ║                                                                              ║
# ║  This is a well-known Anvil/Hardhat default account (#1). Anyone who         ║
# ║  knows this key can steal all funds. It is here ONLY for local               ║
# ║  development against a local Anvil node.                                     ║
# ║                                                                              ║
# ║  For production, generate a fresh key and store it securely.                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
AIRNODE_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# API keys — replace with real values for your providers
COINGECKO_API_KEY=test-coingecko-key
WEATHER_API_KEY=test-weather-key
RANDOM_ORG_TOKEN=test-random-token
CLIENT_API_KEY=test-client-key

# Push target configuration — for pushing signed data to a cache server
AIRNODE_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
CACHE_SERVER_AUTH_TOKEN=test-cache-token
