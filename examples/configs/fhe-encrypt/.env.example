# FHE encryption example — encrypted oracle data for fhEVM-compatible chains.
#
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  WARNING: DO NOT USE THIS PRIVATE KEY IN PRODUCTION                          ║
# ║                                                                              ║
# ║  This is a well-known Anvil/Hardhat default account (#1). Anyone who         ║
# ║  knows this key can steal all funds. It is here ONLY for local               ║
# ║  development against a local Anvil node.                                     ║
# ║                                                                              ║
# ║  For production, generate a fresh key and store it securely.                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
AIRNODE_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# FHE plugin — required by examples/plugins/fhe-encrypt/
#
# FHE_NETWORK: Selects the fhEVM chain preset ('sepolia' or 'mainnet').
#   The preset includes all contract addresses, chain IDs, and relayer URLs
#   for the target network. Defaults to 'sepolia' if not set.
FHE_NETWORK=sepolia

# FHE_API_KEY: API key for Zama's hosted relayer. Required for encryption.
#   Get one at https://docs.zama.org — sign up and create a project.
FHE_API_KEY=your-zama-api-key-here

# FHE_NETWORK_URL: Ethereum JSON-RPC endpoint for the target chain.
#   The SDK uses this to interact with on-chain FHE contracts (ACL, KMS verifier).
#   Use any standard Sepolia RPC endpoint — Alchemy, Infura, or a public node.
FHE_NETWORK_URL=https://ethereum-sepolia-rpc.publicnode.com

# FHE_CONTRACT_ADDRESS: The on-chain contract that will receive the encrypted
#   data (e.g. ConfidentialPriceFeed). Encrypted inputs are bound to this address
#   to prevent replay across contracts. Replace with your deployed contract.
FHE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# AIRNODE_ADDRESS: The airnode's public address (derived from AIRNODE_PRIVATE_KEY).
#   Encrypted inputs are also bound to the sender's address. This is Anvil
#   account #1's address, matching the private key above.
AIRNODE_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
